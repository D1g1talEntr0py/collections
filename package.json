{
  "name": "@d1g1tal/collections",
  "author": "D1g1talEntr0py",
  "version": "2.1.6",
  "license": "MIT",
  "description": "JavaScript Collections ES Modules",
  "homepage": "https://github.com/D1g1talEntr0py/collections#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D1g1talEntr0py/collections.git"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/collections/issues"
  },
  "maintainers": [
    {
      "name": "D1g1talEntr0py",
      "email": "jason.dimeo@gmail.com"
    }
  ],
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "/dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsbuild",
    "build:watch": "tsbuild --watch",
    "type-check": "tsbuild --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@d1g1tal/tsbuild": "^1.6.3",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/benchmark": "^2.1.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "benchmark": "^2.1.4",
    "eslint": "^10.0.3",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "microtime": "^3.1.1",
    "typescript-eslint": "8.57.1",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "defaults",
    "not ios_saf < 15",
    "not op_mini all"
  ],
  "keywords": [
    "Collections",
    "Data Structures",
    "ESModules"
  ]
}
