{
  "name": "@d1g1tal/collections",
  "version": "2.1.2",
  "author": "Jason DiMeo",
  "license": "ISC",
  "description": "JavaScript Collections ES Modules",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D1g1talEntr0py/collections.git"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/collections/issues"
  },
  "keywords": [
    "Collections",
    "ESModules"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    }
  },
	  "engines": {
    "node": ">=20.16.0"
  },
	"packageManager": "pnpm@10.30.3",
  "publishConfig": {
		"registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "/src",
    "/dist"
  ],
  "scripts": {
    "build": "tsbuild",
    "build:watch": "tsbuild --watch",
    "type-check": "tsbuild --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "tsx benchmark/*.benchmark.ts",
    "prepublish": "pnpm lint && pnpm test && pnpm build --minify"
  },
  "homepage": "https://github.com/D1g1talEntr0py/collections#readme",
  "devDependencies": {
    "@d1g1tal/tsbuild": "^1.3.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@types/benchmark": "^2.1.5",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "benchmark": "^2.1.4",
    "eslint": "^10.0.2",
    "eslint-plugin-compat": "^7.0.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "globals": "^17.4.0",
    "microtime": "^3.1.1",
    "tsbuild": "link:../tsbuild",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5.5.2"
  },
  "optionalDependencies": {
    "tsx": "^4.21.0"
  },
  "browserslist": [
    "defaults",
    "not ios_saf < 15",
    "not op_mini all"
  ]
}
